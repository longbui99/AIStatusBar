#!/usr/bin/env bash
set -euo pipefail

# ── Resolve project root (follow symlinks first) ──
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"
CONFIG="$SCRIPT_DIR/config.json"
TEMPLATE="$SCRIPT_DIR/utils/plugin.template.py"
PLUGIN_DIR="$HOME/Library/Application Support/SwiftBar/Plugins"

# ── Auto-discover providers from providers/*.py ──
discover_providers() {
    python3 -c "
import pkgutil
from pathlib import Path
d = Path('$SCRIPT_DIR/providers')
for _, name, _ in pkgutil.iter_modules([str(d)]):
    if name.startswith('_'): continue
    src = (d / (name + '.py')).read_text()
    pk = fn = ''
    for line in src.splitlines():
        if line.startswith('PROVIDER_KEY'):
            pk = line.split('=',1)[1].strip().strip('\"').strip(\"'\")
        if line.startswith('FULL_NAME'):
            fn = line.split('=',1)[1].strip().strip('\"').strip(\"'\")
    if pk and fn:
        print(f'{pk}:{fn}')
"
}

# ── Colors ──
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
NC=$'\033[0m'

# ── Helpers ──
info()  { printf '%s\n' "${GREEN}✓${NC} $*"; }
warn()  { printf '%s\n' "${YELLOW}!${NC} $*"; }
err()   { printf '%s\n' "${RED}✗${NC} $*" >&2; }
header(){ printf '\n%s\n' "${BOLD}${CYAN}$*${NC}"; }

usage() {
    cat <<EOF
${BOLD}ai-status-bar${NC} — AI service usage in your macOS menu bar

${BOLD}USAGE${NC}
    ai-status-bar <command>

${BOLD}COMMANDS${NC}
    setup       First-time setup — choose providers and install
    install     Install SwiftBar and enable configured providers
    uninstall   Remove plugins and optionally uninstall SwiftBar
    update      Pull latest changes and reinstall plugins
    config      Open config.json in your default editor
    status      Show which providers are currently active
    logs        Tail the plugin log file
    help        Show this help message

${BOLD}QUICK START${NC}
    ai-status-bar setup       # interactive first-time setup
    ai-status-bar config      # edit providers later
    ai-status-bar install     # re-apply after config changes

${BOLD}REQUIREMENTS${NC}
    macOS, Homebrew, Python 3
EOF
}

# ── Preflight checks ──
check_prereqs() {
    if [ "$(id -u)" -eq 0 ]; then
        err "Do not run ai-status-bar as root/sudo."
        exit 1
    fi
    if [[ "$(uname)" != "Darwin" ]]; then
        err "ai-status-bar only supports macOS."
        exit 1
    fi
    if ! command -v brew &>/dev/null; then
        err "Homebrew is required. Install it from https://brew.sh"
        exit 1
    fi
    if ! command -v python3 &>/dev/null; then
        err "Python 3 is required. Install with: brew install python3"
        exit 1
    fi
}

# ── Commands ──

cmd_setup() {
    printf '%s' "${BOLD}${CYAN}"
    cat <<'BANNER'
    _    ___   ____  _        _               ____
   / \  |_ _| / ___|| |_ __ _| |_ _   _ ___  | __ )  __ _ _ __
  / _ \  | |  \___ \| __/ _` | __| | | / __| |  _ \ / _` | '__|
 / ___ \ | |   ___) | || (_| | |_| |_| \__ \ | |_) | (_| | |
/_/   \_\___| |____/ \__\__,_|\__|\__,_|___/ |____/ \__,_|_|
BANNER
    printf '%s%s\n\n' "${DIM}" "                                          longbui.net${NC}"

    check_prereqs

    # ── Provider descriptions ──
    printf '%s\n\n' "${BOLD}Which providers would you like to enable?${NC}"
    printf '  %s\n' "${DIM}Claude Code — uses your Claude Code OAuth token from macOS Keychain."
    printf '  %s\n' "  Just run 'claude login' if you haven't already."
    printf '  %s\n' "Cursor — reads tokens from Cursor IDE. Only works if Cursor is installed."
    printf '  %s\n\n' "Google Antigravity — connects to Antigravity IDE. Only works if Antigravity is installed.${NC}"

    # ── Read defaults from config.json ──
    local global_config="{}"
    if [ -f "$CONFIG" ]; then
        global_config=$(python3 -c "import json; print(json.dumps(json.load(open('$CONFIG'))))")
    fi

    # ── Ask about each provider ──
    local selections=""
    while IFS=':' read -r key full_name <&3; do
        local default_enabled
        default_enabled=$(python3 -c "
import json
c = json.loads('$global_config')
print('Y' if c.get('$key', {}).get('enabled', False) else 'N')
" 2>/dev/null || echo "N")

        local prompt_hint
        if [ "$default_enabled" = "Y" ]; then
            prompt_hint="Y/n"
        else
            prompt_hint="y/N"
        fi

        printf "  %s? [%s] " "$full_name" "$prompt_hint"
        local answer
        read -r answer </dev/tty 2>/dev/null || read -r answer

        if [ -z "$answer" ]; then
            answer="$default_enabled"
        fi

        if [[ "$answer" =~ ^[Yy]$ ]]; then
            selections="$selections $key:true"
        else
            selections="$selections $key:false"
        fi
    done 3< <(discover_providers)

    # ── Write config.json ──
    python3 -c "
import json; from pathlib import Path
p = Path('$CONFIG')
config = json.load(open(p)) if p.exists() else {
    'working_hours_per_day': 24,
    'thresholds': {'yellow': 80, 'orange': 90, 'red': 100},
    'progress_bar': {'filled': '█', 'empty': '▒', 'width': 4}
}
for item in '$selections'.split():
    if not item: continue
    key, enabled = item.split(':')
    if key not in config:
        config[key] = {'refresh_interval_minutes': 5}
    config[key]['enabled'] = enabled == 'true'
with open('$CONFIG', 'w') as f:
    json.dump(config, f, indent=2, ensure_ascii=False)
    f.write('\n')
"
    info "Saved config.json"

    # ── Run install ──
    printf '\n'
    cmd_install

    # ── Done ──
    printf '\n'
    printf '%s\n' "${BOLD}${GREEN}All set!${NC} AI Status Bar is running in your menu bar."
    printf '\n'
    printf '  %s  $ ai-status-bar config\n' "${DIM}Configure:${NC}"
    printf '  %s     $ ai-status-bar status\n' "${DIM}Status:${NC}"
    printf '  %s     $ ai-status-bar update\n' "${DIM}Update:${NC}"
    printf '  %s  $ ai-status-bar uninstall\n' "${DIM}Uninstall:${NC}"
    printf '\n'
}

cmd_install() {
    header "AI Status Bar — Install"
    check_prereqs

    if [ ! -f "$CONFIG" ]; then
        err "config.json not found. Run: ai-status-bar setup"
        exit 1
    fi

    if [ ! -f "$TEMPLATE" ]; then
        err "utils/plugin.template.py not found. Is the project intact?"
        exit 1
    fi

    # Install SwiftBar if missing
    if ! brew list --cask swiftbar &>/dev/null; then
        info "Installing SwiftBar via Homebrew..."
        brew install --cask swiftbar
    else
        info "SwiftBar already installed."
    fi

    # Find SwiftBar.app
    SWIFTBAR_APP="$(find /opt/homebrew/Caskroom/swiftbar /Applications -name 'SwiftBar.app' -maxdepth 3 2>/dev/null | head -1)"
    if [ -z "$SWIFTBAR_APP" ]; then
        err "Could not find SwiftBar.app"
        exit 1
    fi

    # Clean up old plugins
    mkdir -p "$PLUGIN_DIR"
    rm -f "$PLUGIN_DIR"/ai-status.*.py "$PLUGIN_DIR"/ai-*.py 2>/dev/null || true
    rm -f "$SCRIPT_DIR"/ai-*.py 2>/dev/null || true

    # Generate plugin scripts by auto-discovering providers
    COUNT=0
    while IFS=':' read -r provider_key full_name; do
        enabled=$(python3 -c "import json; c=json.load(open('$CONFIG')); print(c.get('$provider_key',{}).get('enabled',False))" 2>/dev/null || echo "False")
        if [ "$enabled" != "True" ]; then
            warn "Skipped: $full_name (disabled)"
            continue
        fi

        interval=$(python3 -c "import json; c=json.load(open('$CONFIG')); print(c.get('$provider_key',{}).get('refresh_interval_minutes',5))" 2>/dev/null || echo "5")

        plugin_file="$SCRIPT_DIR/ai-${provider_key}.${interval}m.py"

        sed -e "s/{{DESCRIPTION}}/${full_name}/g" \
            -e "s/{{PROVIDER_KEY}}/${provider_key}/g" \
            "$TEMPLATE" > "$plugin_file"
        chmod +x "$plugin_file"

        ln -s "$plugin_file" "$PLUGIN_DIR/$(basename "$plugin_file")"
        info "Installed: $full_name (every ${interval}min)"
        COUNT=$((COUNT + 1))
    done < <(discover_providers)

    if [ "$COUNT" -eq 0 ]; then
        warn "No providers enabled. Run: ai-status-bar setup"
        exit 0
    fi

    # Install daily auto-update via launchd (no admin rights needed)
    local plist_id="com.longbui.ai-status-bar-update"
    local plist_path="$HOME/Library/LaunchAgents/${plist_id}.plist"
    mkdir -p "$HOME/Library/LaunchAgents"
    cat > "$plist_path" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${plist_id}</string>
    <key>ProgramArguments</key>
    <array>
        <string>$(which git)</string>
        <string>-C</string>
        <string>${SCRIPT_DIR}</string>
        <string>pull</string>
        <string>--ff-only</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>1</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>${SCRIPT_DIR}/update.log</string>
    <key>StandardErrorPath</key>
    <string>${SCRIPT_DIR}/update.log</string>
</dict>
</plist>
PLIST
    launchctl bootout "gui/$(id -u)" "$plist_path" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "$plist_path"
    info "Installed daily auto-update (1:00 AM via launchd)."

    # Point SwiftBar to the plugin directory and launch
    defaults write com.ameba.SwiftBar PluginDirectory "$PLUGIN_DIR"
    killall SwiftBar 2>/dev/null || true
    sleep 1
    open "$SWIFTBAR_APP"

    printf '\n'
    info "Done! $COUNT plugin(s) installed — check your menu bar."
}

cmd_uninstall() {
    header "AI Status Bar — Uninstall"

    if pgrep -q SwiftBar; then
        info "Stopping SwiftBar..."
        killall SwiftBar 2>/dev/null || true
        sleep 1
    fi

    if [ -d "$PLUGIN_DIR" ]; then
        info "Removing plugin symlinks..."
        rm -f "$PLUGIN_DIR"/ai-*.py 2>/dev/null || true
    fi

    rm -f "$SCRIPT_DIR"/ai-*.py 2>/dev/null || true

    # Remove auto-update launchd job
    local plist_id="com.longbui.ai-status-bar-update"
    local plist_path="$HOME/Library/LaunchAgents/${plist_id}.plist"
    if [ -f "$plist_path" ]; then
        launchctl bootout "gui/$(id -u)" "$plist_path" 2>/dev/null || true
        rm -f "$plist_path"
        info "Removed daily auto-update job."
    fi

    read -rp "Uninstall SwiftBar via Homebrew? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        info "Uninstalling SwiftBar..."
        brew uninstall --cask swiftbar 2>/dev/null || true
        defaults delete com.ameba.SwiftBar 2>/dev/null || true
    else
        info "Kept SwiftBar installed."
    fi

    printf '\n'
    info "AI Status Bar has been removed."
}

cmd_config() {
    if [ ! -f "$CONFIG" ]; then
        warn "config.json not found. Running setup first..."
        cmd_setup
        return
    fi

    if [ -n "${EDITOR:-}" ]; then
        "$EDITOR" "$CONFIG"
    elif command -v code &>/dev/null; then
        code "$CONFIG"
    elif command -v nano &>/dev/null; then
        nano "$CONFIG"
    else
        open "$CONFIG"
    fi
}

cmd_status() {
    header "AI Status Bar — Status"

    if [ ! -f "$CONFIG" ]; then
        warn "No config.json found. Run: ai-status-bar setup"
        return
    fi

    while IFS=':' read -r provider_key full_name; do
        enabled=$(python3 -c "import json; c=json.load(open('$CONFIG')); print(c.get('$provider_key',{}).get('enabled',False))" 2>/dev/null || echo "False")
        interval=$(python3 -c "import json; c=json.load(open('$CONFIG')); print(c.get('$provider_key',{}).get('refresh_interval_minutes','—'))" 2>/dev/null || echo "—")

        if [ "$enabled" = "True" ]; then
            info "$full_name — enabled (every ${interval}min)"
        else
            warn "$full_name — disabled"
        fi
    done < <(discover_providers)

    printf '\n'
    if pgrep -q SwiftBar; then
        info "SwiftBar is running."
    else
        warn "SwiftBar is not running. Run: ai-status-bar install"
    fi
}

cmd_logs() {
    local logfile="$SCRIPT_DIR/ai-status.log"
    if [ ! -f "$logfile" ]; then
        warn "No log file yet."
        return
    fi
    tail -f "$logfile"
}

cmd_update() {
    header "AI Status Bar — Update"

    info "Pulling latest changes..."
    if ! git -C "$SCRIPT_DIR" pull --ff-only; then
        err "Failed to pull latest changes. Check for local modifications."
        exit 1
    fi

    info "Reinstalling plugins..."
    cmd_install

    printf '\n'
    info "Updated to latest version."
}

# ── Main dispatcher ──
case "${1:-help}" in
    setup)      cmd_setup ;;
    install)    cmd_install ;;
    uninstall)  cmd_uninstall ;;
    update)     cmd_update ;;
    config)     cmd_config ;;
    status)     cmd_status ;;
    logs)       cmd_logs ;;
    help|--help|-h) usage ;;
    *)
        err "Unknown command: $1"
        usage
        exit 1
        ;;
esac
